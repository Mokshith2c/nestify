<% layout("layouts/boilerplate.ejs") -%>

<% const avatarUrl = (profile && profile.avatar && profile.avatar.url) ? profile.avatar.url : "https://images.unsplash.com/vector-1758589026240-001260402d98?q=80&w=1267&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"; %>

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm p-4 profile-card">
            <div class="d-flex align-items-center gap-3">
                <img src="<%= avatarUrl %>" class="profile-avatar" alt="profile avatar">
                <div>
                    <h3 class="mb-1"><%= user.username %></h3>
                    <p class="text-muted mb-0"><%= user.email %></p>
                </div>
            </div>

            <div class="mt-3">
                <h5 class="mb-2">About</h5>
                <p class="mb-0 text-secondary">
                    <%= profile && profile.bio ? profile.bio : "No bio yet." %>
                </p>
            </div>

            <% if (currentUser && currentUser._id.equals(user._id)) { %>
                <div class="mt-4">
                    <a href="/users/<%= user._id %>/edit" class="btn btn-dark">Edit profile</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-12 col-lg-10">
        <h4 class="mb-3" style="text-align: center;">Listings by <%= user.username %></h4>
        <% if (listings.length === 0) { %>
            <p class="text-muted">No listings yet.</p>
        <% } else { %>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
                <% for (let listing of listings) { %>
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <div class="card col listing-card">
                                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 14rem; object-fit: cover;">
                                <div class="card-body">
                                    <p class="card-text">
                                        <b><%= listing.title %></b><br>
                                        &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                                    </p>
                                </div>
                            </div>
                        </a>
                    
                <% } %>
            </div>
        <% } %>
    </div>
</div>

