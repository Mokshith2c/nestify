<% if (success && success.length > 0) { %>
    <div class="d-flex justify-content-center">
        <div class="alert alert-success alert-dismissible fade show shadow-sm d-flex align-items-center w-50 " role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <strong><%= success %></strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
    <% } %>
    <% if (error && error.length > 0) { %>
        <div class="d-flex justify-content-center">
            <div class="alert alert-warning alert-dismissible fade show shadow-sm d-flex align-items-center w-50 " role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <strong><%= error %></strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<% } %>
